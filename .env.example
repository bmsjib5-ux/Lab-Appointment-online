# Copy this file to ".env" and fill in real values. The .env file is git-ignored.
PORT=8780
ONLINE_DB_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE
ONLINE_ALLOW_WRITE=false

# ---- MOPH Provider ID login (optional) ----
# client_id / redirect_uri มาจาก BMS; app_id + secret_key เป็นความลับ (ขอจาก BMS)
# redirect_uri ต้อง "ตรงเป๊ะ" กับที่ลงทะเบียนไว้กับ BMS และชี้มาที่ /login.html ของแอปนี้
PROVIDER_ID_CLIENT_ID=9c42a882-3f47-4609-92c5-e4e00a8ea676
PROVIDER_ID_APP_ID=
PROVIDER_ID_SECRET_KEY=
PROVIDER_ID_REDIRECT_URI=http://localhost:8780/login.html
# ค่าปริยายด้านล่างมักไม่ต้องแก้
PROVIDER_ID_AUTH_URL=https://moph.id.th/oauth/redirect
PROVIDER_ID_TOKEN_URL=https://bms-authen-provider.bmscloud.in.th/api/v1/auth/provider-id
